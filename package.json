{
  "name": "ksp-llm-extension",
  "version": "0.1.0",
  "private": true,
  "description": "KSP Extractor — Hebrew-first browser extension that extracts KSP product listings and feeds them to Claude / GPT / Gemini.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nisanez/ksp-extractor-extension.git"
  },
  "homepage": "https://github.com/Nisanez/ksp-extractor-extension",
  "bugs": {
    "url": "https://github.com/Nisanez/ksp-extractor-extension/issues"
  },
  "scripts": {
    "lint": "web-ext lint --source-dir=extension --self-hosted",
    "zip": "web-ext build --source-dir=extension --artifacts-dir=dist --overwrite-dest",
    "run:firefox": "web-ext run --source-dir=extension --start-url https://ksp.co.il/web/cat/2085..96463..96485"
  },
  "devDependencies": {
    "web-ext": "^8.3.0"
  }
