# Normalize line endings: store text as LF in the repo and check it out as
# LF on every platform. Stops the "LF will be replaced by CRLF" warnings on
# Windows and keeps diffs clean across contributors.
* text=auto eol=lf

# Binary assets — never apply EOL conversion.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
